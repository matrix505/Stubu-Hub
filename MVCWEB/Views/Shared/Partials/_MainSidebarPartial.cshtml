<script type="text/javascript">
                     document.addEventListener("DOMContentLoaded", function() {
        const sidebar = document.querySelector(".sidebar");
        const toggler = document.querySelector(".navbar-toggler");
        const icon = toggler.querySelector("i");

        toggler.addEventListener("click", () => {
            sidebar.classList.toggle("collapsed");


            icon.classList.toggle("bx bx-menu");
            icon.classList.toggle("bx bx-menu");
        });
    });
</script>

<div class="sidebar">

    <div class="sidebar-header">
        <button class="navbar-toggler">
            <i class="bx bx-menu"></i>
        </button>
    </div>
    <div class="sidebar-profile">
        <div class="user-information-container">

            <div class="profile-img">
                <img src="~/Assets/Images/collab-content3.png" />
            </div>

            <div class="profile-information">
                <span id="user-name" class="user-information">Sebastian, Hermano</span>
                <span id="user-email" class="user-information">sebastianhedsadsadasdaasrmano@gmail.com</span>
            </div>
        </div>
    </div>

    <ul class="sidebar-nav flex-grow-1">

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-user-circle"></i>
                <span class="links_name">Profile</span>
            </a>
        </li>

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-folder"></i>
                <span class="links_name">My Projects</span>
            </a>
        </li>

        <li class="sidenav-item">
            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bx bx-folder-check"></i>
