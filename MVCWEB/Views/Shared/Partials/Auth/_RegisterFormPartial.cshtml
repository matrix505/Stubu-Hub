@using MVCWEB.ViewModel.Account
@model RegisterViewModel
@*
*@
@{

}

<div class="container mb-3 register-form-partial">
    <h1>Register Page</h1>
    <form asp-action="register" asp-controller="auth" method="POST">
        @Html.AntiForgeryToken()

        <div class="row row-cols-1 row-cols-md-2">
            <div class="form-group col">
                <label asp-for="FirstName">First name</label>
                <input class="form-control" asp-for="FirstName" />
                <span class="text-danger" asp-validation-for="FirstName"></span>
            </div>
            <div class="form-group col">
                <label asp-for="LastName">Last name</label>
                <input class="form-control" asp-for="LastName" />
                <span class="text-danger" asp-validation-for="LastName"></span>
            </div>
            <div class="form-group col">
                <label asp-for="Email">Email</label>
                <input class="form-control" asp-for="Email" />
                <span class="text-danger" asp-validation-for="Email"></span>
            </div>
            <div class="form-group col">
                <label asp-for="Username">Username</label>
                <input class="form-control" asp-for="Username" />
                <span class="text-danger" asp-validation-for="Username"></span>
            </div>
            <div class="form-group col">
                <label asp-for="Password">Password</label>
                <input class="form-control" asp-for="Password" />
                <span class="text-danger" asp-validation-for="Password"></span>
            </div>
            <div class="form-group col">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input class="form-control" asp-for="ConfirmPassword" />
                <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
            </div>
            <div class="form-group col">
                <label asp-for="Birthdate">Date of birth</label>
                <input type="date" class="form-control" asp-for="Birthdate" />
            </div>
            <div class="form-group col">
                <label asp-for="Country">Country</label>
                <select class="form-select" asp-for="Country">
                    <option value="Philippines" selected>PH</option>
                </select>
                <span class="text-danger" asp-validation-for="Country"></span>
            </div>

        </div>

        <div class="form-group d-flex justify-content-end">
            <button type="submit" class="btn btn-primary ">Sign up</button>
        </div>
    </form>
</div>
