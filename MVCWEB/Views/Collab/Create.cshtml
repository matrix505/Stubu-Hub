@using MVCWEB.ViewModel.Collab
@model CollabCreateViewModel

@{
    Layout = "_MainLayout";
    ViewData["Title"] = "Create Project";
}

<div class="container py-4" >


    <div class="mb-4">
        <h4 class="fw-bold mb-1">Create New Project</h4>
        <p class="text-muted small mb-0">Create new project for collaboration</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">

            <form asp-action="Create" asp-controller="Collab" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

     
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control"
                           placeholder="Enter project title" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"
                              placeholder="Describe your project..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="MemberSize" class="form-label fw-semibold"></label>
                        <select asp-for="MemberSize" class="form-select">
                            <option value="">-- Select size --</option>
                            <option value="1">1 - Solo</option>
                            <option value="5">Up to 5</option>
                            <option value="10">Up to 10</option>
                            <option value="20">Up to 20</option>
                            <option value="50">Up to 50</option>
                        </select>
                        <span asp-validation-for="MemberSize" class="text-danger small"></span>
                    </div>
                    @* <div class="col-md-6">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="Planning">Planning</option>
                            <option value="Active">Active</option>
                            <option value="OnHold">On Hold</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div> *@
                </div>
                <div class="row row-cols-1 row-cols-md-2">
                <div class="mb-4">
                    <div class="d-flex flex-column">
                        <label class="form-label fw-semibold">Categories</label>
                        <small class="text-muted">Select at least three categories</small>
                    </div>
                    <div class="d-flex flex-wrap gap-2 p-3 border rounded bg-light">
                        @{

                        }

                        @foreach (var cat in Model.Categories)
                        {
                            <input type="checkbox"
                                   class="btn-check"
                                   name="SelectedCategoryIds"
                                   value="@cat.Category_id"
                                   id="cat_@cat.Category_id"
                                   autocomplete="off" />
                            <label class="btn btn-sm btn-outline-primary"
                                   for="cat_@cat.Category_id">
                                @cat.Category_name
                            </label>
                        }
                    </div>
                    @* <span asp-validation-for="SelectedCategoryIds" class="text-danger small"></span> *@
                </div>

                <div class="mb-4">
                   <div class="d-flex flex-column">
                            <label class="form-label fw-semibold">Skills</label>
                            <small class="text-muted">Skills required in this project</small>
                   </div>
                    <div class="d-flex flex-wrap gap-2 p-3 border rounded bg-light">
                        @foreach (var skills in Model.Skills)
                        {
                            <input type="checkbox"
                                   class="btn-check "
                                   name="SelectedSkillIds"
                                   value="@skills.Skill_id"
                                   id="sk_@skills.Skill_id"
                                   autocomplete="off" />
                            <label class="btn btn-sm btn-outline-dark"
                                   for="sk_@skills.Skill_id">
                                @skills.Skill_name
                            </label>
                        }
                    </div>
                    @* <span asp-validation-for="SelectedSkillIds" class="text-danger small"></span> *@
                </div>
                </div>
     
                <div class="d-flex align-items-center justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-plus-circle me-2"></i>Create Project
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("Partials/_ValidationScriptsPartial");
    }
}